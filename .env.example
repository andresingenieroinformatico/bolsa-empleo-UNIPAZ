APP_NAME="Bolsa de Empleo UNIPAZ"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-app.up.railway.app

LOG_CHANNEL=stack
LOG_LEVEL=error

# ─── Base de datos (SQLite para Railway gratis) ───────────
DB_CONNECTION=sqlite
DB_DATABASE=/app/database/database.sqlite

# ─── Correo electrónico ───────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu-correo@unipaz.edu.co
MAIL_PASSWORD=tu-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=bolsaempleo@unipaz.edu.co
MAIL_FROM_NAME="Bolsa de Empleo UNIPAZ"

# ─── Google OAuth (Socialite) ─────────────────────────────
# Crear en: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-google-client-secret
GOOGLE_REDIRECT_URI=https://tu-app.up.railway.app/auth/google/callback

# ─── Sistema de colas ─────────────────────────────────────
QUEUE_CONNECTION=database

# ─── Sesión y caché ───────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file

# ─── Almacenamiento ───────────────────────────────────────
FILESYSTEM_DISK=public

# ─── Credenciales Iniciales (Seeder) ──────────────────────
ADMIN_INITIAL_EMAIL=admin@unipaz.edu.co
ADMIN_INITIAL_PASSWORD=
TEST_COMPANY_EMAIL=info@tecnosoluciones.com
TEST_COMPANY_PASSWORD=
TEST_STUDENT_EMAIL=carlos.lopez@unipaz.edu.co
TEST_STUDENT_PASSWORD=
